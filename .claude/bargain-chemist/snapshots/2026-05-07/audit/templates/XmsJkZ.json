<tr>\n<td style=\"padding:32px 40px 24px 40px;font-family:Helvetica,Arial,sans-serif;font-size:15px;color:#333333;line-height:1.7;\">\n<p style=\"margin:0 0 18px 0;\">\n                  Hi {{ first_name|default:'there' }},\n                </p>\n<p style=\"margin:0;\">\n                  Feeling rough? You're not alone \u2014 flu season is in full swing across New Zealand. The good news: with the right support your body can recover well. Below are our pharmacist-backed tips and the products most people reach for when they're fighting off a cold or flu.\n                </p>\n</td>\n</tr>\n<!-- DIVIDER -->\n<tr>\n<td style=\"background-color:#ffffff;padding:0 40px;\">\n<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\">\n<tr>\n<td style=\"border-top:1px solid #eeeeee;font-size:0;height:1px;\">\n</td>\n</tr>\n</table>\n</td>\n</tr>\n<!-- 3 RECOVERY TIPS -->\n<tr>\n<td style=\"padding:32px 40px;\">\n<h2 style=\"margin:0 0 24px;color:#1a1a1a;font-size:20px;font-family:Helvetica,Arial,sans-serif;text-align:center;\">\n                  3 Ways to Support Recovery\n                </h2>\n<!-- Tip 1 -->\n<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin-bottom:20px;\" width=\"100%\">\n<tr>\n<td valign=\"top\" width=\"48\">\n<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\">\n<tr>\n<td style=\"background:#FF0031;color:#ffffff;font-size:18px;font-family:Helvetica,Arial,sans-serif;font-weight:bold;width:36px;height:36px;text-align:center;border-radius:50%;line-height:36px;\">\n                            1\n                          </td>\n</tr>\n</table>\n</td>\n<td style=\"padding-left:12px;\" valign=\"top\">\n<p style=\"margin:0 0 4px;color:#1a1a1a;font-size:15px;font-family:Helvetica,Arial,sans-serif;font-weight:bold;\">\n                        Top up Zinc &amp; Vitamin C early\n                      </p>\n<p style=\"margin:0;color:#555555;font-size:14px;font-family:Helvetica,Arial,sans-serif;line-height:1.6;\">\n                        Both nutrients support your immune response. Start as soon as you notice symptoms.\n                      </p>\n</td>\n</tr>\n</table>\n<!-- Tip 2 -->\n<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin-bottom:20px;\" width=\"100%\">\n<tr>\n<td valign=\"top\" width=\"48\">\n<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\">\n<tr>\n<td style=\"background:#FF0031;color:#ffffff;font-size:18px;font-family:Helvetica,Arial,sans-serif;font-weight:bold;width:36px;height:36px;text-align:center;border-radius:50%;line-height:36px;\">\n                            2\n                          </td>\n</tr>\n</table>\n</td>\n<td style=\"padding-left:12px;\" valign=\"top\">\n<p style=\"margin:0 0 4px;color:#1a1a1a;font-size:15px;font-family:Helvetica,Arial,sans-serif;font-weight:bold;\">\n                        Manage symptoms so you can rest\n                      </p>\n<p style=\"margin:0;color:#555555;font-size:14px;font-family:Helvetica,Arial,sans-serif;line-height:1.6;\">\n                        Sleep is when your immune system does its best work. A quality cold &amp; flu day/night formula helps keep you comfortable.\n                      </p>\n</td>\n</tr>\n</table>\n<!-- Tip 3 -->\n<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\">\n<tr>\n<td valign=\"top\" width=\"48\">\n<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\">\n<tr>\n<td style=\"background:#FF0031;color:#ffffff;font-size:18px;font-family:Helvetica,Arial,sans-serif;font-weight:bold;width:36px;height:36px;text-align:center;border-radius:50%;line-height:36px;\">\n                            3\n                          </td>\n</tr>\n</table>\n</td>\n<td style=\"padding-left:12px;\" valign=\"top\">\n<p style=\"margin:0 0 4px;color:#1a1a1a;font-size:15px;font-family:Helvetica,Arial,sans-serif;font-weight:bold;\">\n                        Rebuild gut health with probiotics\n                      </p>\n<p style=\"margin:0;color:#555555;font-size:14px;f