ortant;\n        padding-right: 20px !important\n        }\n    .header, .hero {\n        padding-left: 20px !important;\n        padding-right: 20px !important\n        }\n    .hero h1 {\n        font-size: 22px !important\n        }\n    }</style></head>\n<body>\n<div class=\"wrapper\">\n<div class=\"container\">\n<!-- Header -->\n<div class=\"header\">\n<img alt=\"Bargain Chemist\" src=\"https://d3k81ch9hvuctc.cloudfront.net/company/VPz6ko/images/ede5b27c-b18e-4975-8c1b-65c48eba5523.png\"/>\n</div>\n<!-- Hero -->\n<div class=\"hero\">\n<h1>Order confirmed! \u2713</h1>\n<p>Thanks {{ first_name|default:'for your order' }}, we're getting it ready for you.</p>\n</div>\n<!-- Order summary -->\n<div class=\"section\">\n<h2>Your order details</h2>\n<div class=\"order-box\">\n<div class=\"order-num\">Order number: <strong>#{{ event.OrderId|default:'\u2014' }}</strong></div>\n<div class=\"order-num\">Items: <strong>{{ event.ItemCount|default:'\u2014' }} item{{ event.ItemCount|pluralize }}</strong></div>\n<div class=\"order-num\">Total: <strong>${{ event.OrderValue|default:'\u2014' }}</strong></div>\n</div>\n<p style=\"font-size:14px;color:#555;margin:0;\">We'll send a shipping confirmation with your tracking details as soon as your order is on its way.</p>\n</div>\n<hr class=\"divider\"/>\n<!-- What happens next -->\n<div class=\"next-steps\">\n<h2 style=\"font-size:18px;font-weight:700;color:#1a1a1a;margin:20px 0 16px;border-bottom:2px solid #FF0031;padding-bottom:10px;\">What happens next</h2>\n<table style=\"border-collapse:collapse;width:100%;\">\n<tr>\n<td style=\"width:52px;vertical-align:top;padding:0 16px 16px 0;\">\n<div style=\"width:36px;height:36px;background-color:#FF0031;border-radius:50%;color:#fff;font-size:15px;font-weight:700;line-height:36px;text-align:center;\">1</div>\n</td>\n<td style=\"vertical-align:top;padding-bottom:16px;\">\n<strong style=\"display:block;font-size:14px;color:#1a1a1a;margin-bottom:3px;\">We're packing your order</strong>\n<span s