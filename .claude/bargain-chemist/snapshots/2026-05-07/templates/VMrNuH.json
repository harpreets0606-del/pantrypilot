{"data":{"type":"template","id":"VMrNuH","attributes":{"name":"[Z] Welcome Series - Email 2 - Price Beat","editor_type":"CODE","html":"<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1\" name=\"viewport\"/>\n<style>body {\n    margin: 0;\n    padding: 0;\n    background-color: #f7f7f7\n    }\nimg {\n    border: 0;\n    display: block;\n    max-width: 100%\n    }\na {\n    color: #FF0031;\n    text-decoration: underline\n    }\n@media only screen and (max-width: 480px) {\n    .wrapper {\n        width: 100% !important;\n        max-width: 100% !important\n        }\n    h1 {\n        font-size: 22px !important;\n        line-height: 1.3 !important\n        }\n    }</style></head>\n<body style=\"margin:0;padding:0;background-color:#f7f7f7;word-spacing:normal;\">\n<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"background-color:#f7f7f7;\" width=\"100%\">\n<tr><td align=\"center\" style=\"padding:10px 0 20px 0;\">\n<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"wrapper\" style=\"max-width:600px;width:600px;background-color:#ffffff;\" width=\"600\">\n<!-- HEADER -->\n<tr><td align=\"center\" style=\"background-color:#FF0031;padding:30px 10px 0 10px;\">\n<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\">\n<tr><td align=\"center\" style=\"padding-bottom:20px;\">\n<a href=\"https://www.bargainchemist.co.nz/\" style=\"text-decoration:none;\">\n<img alt=\"Bargain Chemist\" src=\"https://d3k81ch9hvuctc.cloudfront.net/company/XCgiqg/images/65fb5fbb-6bce-4df9-995e-bfa1bad9d04d.png\" style=\"width:280px;max-width:100%;height:auto;\" width=\"280\"/>\n</a>\n</td></tr>\n<tr><td align=\"center\" style=\"padding-bottom:14px;\">\n<a href=\"https://www.bargainchemist.co.nz/collections/all\" style=\"color:#ffffff;text-decoration:none;font-family:Helvetica,Arial,sans-serif;font-size:12px;letter-spacing:1px;padding:8px 14px;display:inline-block;\">Shop Now</a>\n<span style=\"color:#ffffff;font-family:Helvetica,Arial,sans-serif;font-size:12px;\">|</span>\n<a href=\"https://www.bargainchemist.co.nz/pages/find-a-store\" style=\"color:#ffffff;text-decoration:none;font-family:Helvetica,Arial,sans-serif;font-size:12px;letter-spacing:1px;padding:8px 14px;display:inline-block;\">Find a Pharmacy</a>\n</td></tr>\n</table>\n</td></tr>\n<!-- HERO -->\n<tr><td align=\"center\" style=\"background-color:#ffffff;padding:36px 30px 24px 30px;\">\n<p style=\"font-family:Helvetica,Arial,sans-serif;font-size:13px;font-weight:600;color:#FF0031;text-transform:uppercase;letter-spacing:2px;margin:0 0 10px 0;padding-bottom:0;\">Our Promise to You</p>\n<h1 style=\"font-family:Helvetica,Arial,sans-serif;font-size:28px;font-weight:bold;color:#222222;line-height:1.2;margin:0 0 14px 0;\">We'll beat any pharmacy price \u2014 guaranteed</h1>\n<p style=\"font-family:Helvetica,Arial,sans-serif;font-size:15px;color:#555555;line-height:1.6;margin:0;padding-bottom:0;\">At Bargain Chemist, your money goes further. That's a promise.</p>\n</td></tr>\n<!-- PRICE BEAT CALLOUT -->\n<tr><td style=\"background-color:#fff5f5;border-top:3px solid #FF0031;border-bottom:3px solid #FF0031;padding:28px 40px;\">\n<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\">\n<tr>\n<td style=\"width:56px;vertical-align:top;padding-right:18px;font-size:44px;line-height:1;\">\ud83c\udfc6</td>\n<td style=\"vertical-align:top;font-family:Helvetica,Arial,sans-serif;\">\n<p style=\"font-size:17px;font-weight:bold;color:#222222;margin:0 0 8px 0;padding-bottom:0;\">Price Beat Guarantee</p>\n<p style=\"font-size:14px;color:#555555;line-height:1.6;margin:0;padding-bottom:0;\">Find an identical in-stock product cheaper at another New Zealand pharmacy? We will beat that price by 10%. No questions asked.</p>\n</td>\n</tr>\n</table>\n</td></tr>\n<!-- BODY -->\n<tr><td style=\"padding:28px 40px 28px 40px;font-family:Helvetica,Arial,sans-serif;font-size:15px;color:#333333;line-height:1.7;\">\n<p style=\"margin:0 0 18px 0;\">Hi {{ first_name|default:'there' }},</p>\n<p style=\"margin:0 0 18px 0;\">Bargain Chemist has been serving New Zealanders since 1984 \u2014 that's over 40 years of trusted pharmacy care. With stores across the country and one of NZ's largest online pharmacy ranges, we make it easy to get everything you need at the best price.</p>\n<p style=\"margin:0 0 28px 0;\">We stock thousands of products across vitamins, skincare, haircare, baby, personal care, weight management and more. All at prices that beat the competition.</p>\n<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\">\n<tr><td align=\"center\">\n<a href=\"https://www.bargainchemist.co.nz/collections/all\" style=\"display:inline-block;font-family:Helvetica,Arial,sans-serif;font-size:16px;font-weight:bold;color:#ffffff;text-decoration:none;padding:16px 48px;border-radius:4px;background-color:#FF0031;\">Shop at NZ's Best Prices</a>\n</td></tr>\n</table>\n</td></tr>\n<!-- TRUST LIST -->\n<tr><td style=\"background-color:#f9f9f9;border-top:1px solid #eeeeee;border-bottom:1px solid #eeeeee;padding:24px 40px;\">\n<p style=\"font-family:Helvetica,Arial,sans-serif;font-size:13px;font-weight:bold;color:#FF0031;text-transform:uppercase;letter-spacing:1px;margin:0 0 16px 0;padding-bottom:0;\">Why New Zealanders choose Bargain Chemist</p>\n<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\">\n<tr><td style=\"font-family:Helvetica,Arial,sans-serif;font-size:14px;color:#444444;line-height:1.6;padding-bottom:8px;\">\u2713 \u00a0Trusted NZ pharmacy since 1984</td></tr>\n<tr><td style=\"font-family:Helvetica,Arial,sans-serif;font-size:14px;color:#444444;line-height:1.6;padding-bottom:8px;\">\u2713 \u00a0Beat any pharmacy price by 10%</td></tr>\n<tr><td style=\"font-family:Helvetica,Arial,sans-serif;font-size:14px;color:#444444;line-height:1.6;padding-bottom:8px;\">\u2713 \u00a0Free shipping on orders over $79</td></tr>\n<tr><td style=\"font-family:Helvetica,Arial,sans-serif;font-size:14px;color:#444444;line-height:1.6;padding-bottom:8px;\">\u2713 \u00a0Stores nationwide plus fast online delivery</td></tr>\n<tr><td style=\"font-family:Helvetica,Arial,sans-serif;font-size:14px;color:#444444;line-height:1.6;\">\u2713 \u00a0Expert pharmacist advice you can trust</td></tr>\n</table>\n</td></tr>\n<!-- DIVIDER -->\n<tr><td style=\"background-color:#ffffff;padding:0 30px;\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\"><tr><td style=\"border-top:1px solid #eeeeee;font-size:0;height:1px;\"> </td></tr></table></td></tr>\n<!-- SOCIAL -->\n<tr><td align=\"center\" style=\"background-color:#ffffff;padding:24px 30px 28px 30px;\">\n<p style=\"font-family:Helvetica,Arial,sans-serif;font-size:18px;font-weight:bold;color:#222222;text-align:center;margin:0 0 16px 0;padding-bottom:0;\">Get social with us!</p>\n<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\"><tr>\n<td style=\"padding:0 8px;\"><a href=\"https://tiktok.com/@bargainchemistnz\" style=\"text-decoration:none;\"><img alt=\"TikTok\" src=\"https://d3k81ch9hvuctc.cloudfront.net/assets/email/buttons/black/tiktok_96.png\" style=\"width:40px;height:40px;\" width=\"40\"/></a></td>\n<td style=\"padding:0 8px;\"><a href=\"https://www.facebook.com/BargainChemist/\" style=\"text-decoration:none;\"><img alt=\"Facebook\" src=\"https://d3k81ch9hvuctc.cloudfront.net/assets/email/buttons/black/facebook_96.png\" style=\"width:40px;height:40px;\" width=\"40\"/></a></td>\n<td style=\"padding:0 8px;\"><a href=\"https://instagram.com/bargainchemistnz\" style=\"text-decoration:none;\"><img alt=\"Instagram\" src=\"https://d3k81ch9hvuctc.cloudfront.net/assets/email/buttons/black/instagram_96.png\" style=\"width:40px;height:40px;\" width=\"40\"/></a></td>\n<td style=\"padding:0 8px;\"><a href=\"https://nz.linkedin.com/company/bargain-chemist\" style=\"text-decoration:none;\"><img alt=\"LinkedIn\" src=\"https://d3k81ch9hvuctc.cloudfront.net/company/XCgiqg/images/791081ec-bce5-4d35-9ee4-aa35ada53088.png\" style=\"width:40px;height:40px;\" width=\"40\"/></a></td>\n</tr></table>\n</td></tr>\n<!-- LEGAL -->\n<tr><td align=\"center\" style=\"background-color:#FF0031;padding:15px 30px 10px 30px;\">\n<p style=\"font-family:Helvetica,Arial,sans-serif;font-size:9px;color:#ffffff;line-height:1.5;text-align:center;margin:0;padding-bottom:0;\">Please note that not all products may be available in all stores, please call your closest Bargain Chemist pharmacy or visit our <a href=\"https://www.bargainchemist.co.nz/pages/find-a-store\" style=\"color:#ffffff;text-decoration:underline;\">store locator</a>. Prices shown are online prices only and may differ to in store. <a href=\"https://www.bargainchemist.co.nz/pages/best-price-guarantee-our-policy-new-zealands-cheapest-chemist\" style=\"color:#ffffff;text-decoration:underline;\">Price beat guarantee</a> \u2014 If you find a cheaper everyday price on an identical in-stock item at a New Zealand pharmacy we will beat the difference by 10%. *Vitamins and minerals are supplementary to and not a replacement for a balanced diet. Always read the label, use only as directed. If symptoms persist, see your healthcare professional. Weight management products should be used with a balanced diet and exercise.</p>\n</td></tr>\n<tr><td align=\"center\" style=\"background-color:#FF0031;padding:8px 18px 20px 18px;\">\n<p style=\"font-family:Helvetica,Arial,sans-serif;font-size:11px;color:#ffffff;text-align:center;line-height:1.5;margin:0;padding-bottom:0;\">No longer want to receive these emails? {% unsubscribe 'Unsubscribe' %}.<br/>{{ organization.name }} {{ organization.full_address }}</p>\n</td></tr>\n</table>\n</td></tr>\n</table>\n</body>\n</html>","text":null,"amp":null,"created":"2026-05-05T04:31:33+00:00","updated":"2026-05-05T04:31:33+00:00"},"links":{"self":"https://a.klaviyo.com/api/templates/VMrNuH/"}},"links":{"self":"https://a.klaviyo.com/api/templates/VMr