{"data":{"type":"template","id":"RJhLMj","attributes":{"name":"[COMPLIANCE] msg_Vsd32N","editor_type":"CODE","html":"<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1\" name=\"viewport\"/>\n<style>body {\n    margin: 0;\n    padding: 0;\n    background-color: #f7f7f7\n    }\nimg {\n    border: 0;\n    display: block;\n    max-width: 100%\n    }\na {\n    color: #FF0031;\n    text-decoration: underline\n    }\n@media only screen and (max-width: 480px) {\n    .wrapper {\n        width: 100% !important;\n        max-width: 100% !important\n        }\n    h1 {\n        font-size: 22px !important;\n        line-height: 1.3 !important\n        }\n    td[width=\"50%\"] {\n        display: block !important;\n        width: 100% !important;\n        box-sizing: border-box !important\n        }\n    }</style></head>\n<body style=\"margin:0;padding:0;background-color:#f7f7f7;word-spacing:normal;\">\n<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"background-color:#f7f7f7;\" width=\"100%\">\n<tr><td align=\"center\" style=\"padding:10px 0 20px 0;\">\n<table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"wrapper\" style=\"max-width:600px;width:600px;background-color:#ffffff;\" width=\"600\">\n<!-- HEADER -->\n<tr><td align=\"center\" style=\"background-color:#FF0031;padding:30px 10px 0 10px;\">\n<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\">\n<tr><td align=\"center\" style=\"padding-bottom:20px;\">\n<a href=\"https://www.bargainchemist.co.nz/\" style=\"text-decoration:none;\">\n<img alt=\"Bargain Chemist\" src=\"https://d3k81ch9hvuctc.cloudfront.net/company/XCgiqg/images/65fb5fbb-6bce-4df9-995e-bfa1bad9d04d.png\" style=\"width:280px;max-width:100%;height:auto;\" width=\"280\"/>\n</a>\n</td></tr>\n<tr><td align=\"center\" style=\"padding-bottom:14px;\">\n<a href=\"https://www.bargainchemist.co.nz/collections/all\" style=\"color:#ffffff;text-decoration:none;font-family:Helvetica,Arial,sans-serif;font-size:12px;letter-spacing:1px;padding:8px 14px;display:inline-block;\">Shop Now</a>\n<span style=\"color:#ffffff;font-family:Helvetica,Arial,sans-serif;font-size:12px;\">|</span>\n<a href=\"https://www.bargainchemist.co.nz/pages/find-a-store\" style=\"color:#ffffff;text-decoration:none;font-family:Helvetica,Arial,sans-serif;font-size:12px;letter-spacing:1px;padding:8px 14px;display:inline-block;\">Find a Pharmacy</a>\n</td></tr>\n</table>\n</td></tr>\n<!-- HERO -->\n<tr><td align=\"center\" style=\"background-color:#ffffff;padding:36px 30px 24px 30px;\">\n<p style=\"font-family:Helvetica,Arial,sans-serif;font-size:13px;font-weight:600;color:#FF0031;text-transform:uppercase;letter-spacing:2px;margin:0 0 10px 0;padding-bottom:0;\">Still Here For You</p>\n<h1 style=\"font-family:Helvetica,Arial,sans-serif;font-size:28px;font-weight:bold;color:#222222;line-height:1.2;margin:0 0 14px 0;\">Whenever you're ready, {{ first_name|default:'there' }}</h1>\n<p style=\"font-family:Helvetica,Arial,sans-serif;font-size:15px;color:#555555;line-height:1.6;margin:0;padding-bottom:0;\">NZ's best pharmacy prices are always here waiting for you.</p>\n</td></tr>\n<!-- BODY -->\n<tr><td style=\"padding:8px 40px 28px 40px;font-family:Helvetica,Arial,sans-serif;font-size:15px;color:#333333;line-height:1.7;\">\n<p style=\"margin:0 0 18px 0;\">Hi {{ first_name|default:'there' }},</p>\n<p style=\"margin:0 0 18px 0;\">We know life gets busy. Whether you need to restock your vitamins, pick up skincare essentials, or try something new \u2014 Bargain Chemist is always here with NZ's lowest pharmacy prices.</p>\n<p style=\"margin:0 0 28px 0;\">Thousands of products across all your health and wellness needs, delivered fast to your door. And if you find it cheaper elsewhere in NZ, <strong>we'll beat the price by 10%.</strong></p>\n<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\">\n<tr><td align=\"center\">\n<a href=