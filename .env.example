# Dashboard port (default: 3030)
DASHBOARD_PORT=3030

# ── Google Ads ──────────────────────────────────────────────────────────────
# From Google Cloud Console → OAuth 2.0 credentials
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
# From Google Ads API → Apply for a developer token
GOOGLE_ADS_DEVELOPER_TOKEN=
# Bargain Chemist Google Ads Customer ID (digits only, no dashes)
GOOGLE_ADS_CUSTOMER_ID=
# OAuth refresh token (run the OAuth flow once to generate)
GOOGLE_ADS_REFRESH_TOKEN=

# ── Google Analytics 4 ──────────────────────────────────────────────────────
# GA4 Property ID (numeric, e.g. 123456789)
GA4_PROPERTY_ID=
# Service Account credentials (from Google Cloud Console → IAM → Service Accounts)
GA4_CLIENT_EMAIL=
# Paste the private key exactly, with literal \n for newlines
GA4_PRIVATE_KEY=
